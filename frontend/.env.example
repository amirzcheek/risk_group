# ───────────────────────────────────────────────────────────────────────────
# Конфигурация фронтенда (Next.js). Скопируйте в frontend/.env.local.
# Эти переменные читаются ТОЛЬКО на сервере Next (серверный прокси), браузеру
# адрес бэкенда и токен не отдаются.
# ───────────────────────────────────────────────────────────────────────────

# Адрес бэкенда (FastAPI). Внутри сети вуза.
RISK_API_BASE=http://localhost:8000

# Сервисный токен бэкенда (для защищённых операций, если фронт их вызывает).
# Совпадает с SERVICE_TOKEN бэкенда. НЕ префикс NEXT_PUBLIC_ — наружу не уходит.
RISK_SERVICE_TOKEN=change-me-please

# Идентификатор/роль текущего пользователя (эдвайзер/декан) для журнала доступа.
# В реальной платформе подставляется из вашей системы аутентификации (SSO).
RISK_ACTOR=advisor@knus.edu.kz

# Роль пользователя. В ПРОДЕ роль приходит ИЗ ПОРТАЛА per-request через заголовок
# x-user-role (его проставляет шлюз/SSO портала). Раздел «Должники · Летник»
# доступен ТОЛЬКО роли портала "admin".
# RISK_ROLE ниже — ЛОКАЛЬНЫЙ ФОЛЛБЭК для разработки, когда заголовка нет.
# Поставьте admin, чтобы увидеть админ-раздел локально; иначе он скрыт и закрыт (403).
RISK_ROLE=advisor
