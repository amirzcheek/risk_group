# ───────────────────────────────────────────────────────────────────────────
# Конфигурация бэкенда системы группы риска (Early Warning).
# Скопируйте в backend/.env и подставьте реальные адреса внутри сети вуза.
# Ничего не хардкодим в коде — все адреса и токены только здесь.
# Персональные данные строго внутри сети; наружу ничего не уходит.
# ───────────────────────────────────────────────────────────────────────────

# ── Источник данных ──
# synthetic — работать на сгенерированных CSV (демо/разработка без Платонуса);
# platonus  — выполнять SQL из data_queries.yaml в MySQL Платонуса (read-only).
DATA_SOURCE=synthetic

# ── Платонус (MySQL, доступ ТОЛЬКО на чтение). Нужно при DATA_SOURCE=platonus ──
PLATONUS_HOST=platonus-db.internal
PLATONUS_PORT=3306
PLATONUS_DB=platonus
PLATONUS_USER=readonly_user
PLATONUS_PASSWORD=change-me
# Список учебных периодов для выгрузки (через запятую). Если пусто — берутся
# периоды по умолчанию из synthetic_data.TERMS.
PLATONUS_TERMS=2024-1,2024-2,2025-1

# ── Хранилище признаков/прогнозов/журнала ──
# Если оставить пустым — включится локальный SQLite (backend/data/risk.db),
# и весь пайплайн работает без поднятого Postgres. Для прода укажите строку.
DATABASE_URL=postgresql://risk:risk@localhost:5432/risk_group
# SQLITE_PATH=./data/risk.db

# ── Параметры риска ──
# Неделя отсечки: признаки строятся на состояние до неё, метка — отчисление позже.
CUTOFF_WEEK=6
# Доля флага группы риска (топ-X% по вероятности) — управление нагрузкой эдвайзеров.
RISK_TOP_FRACTION=0.10
# Пороги уровней риска для подсветки в UI.
RISK_THRESHOLD_HIGH=0.60
RISK_THRESHOLD_MEDIUM=0.30

# ── LLM для текста уведомлений (Qwen3-14B через OVMS). ТОЛЬКО оформление текста. ──
# Если пусто — работает локальная заглушка (текст из факторов), LLM не требуется.
LLM_BASE_URL=http://ovms.internal:8000/v3
LLM_MODEL=Qwen3-14B
LLM_API_KEY=not-needed

# ── Безопасность ──
# Токен для защищённых операций (/score/run, /train, /notify/run), заголовок X-Service-Token.
SERVICE_TOKEN=change-me-please
# Домены фронтенда, которым разрешён доступ из браузера (через запятую).
CORS_ORIGINS=https://ai.knus.edu.kz,http://localhost:3000
